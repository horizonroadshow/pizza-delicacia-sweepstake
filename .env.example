# Server-only API-Football / API-SPORTS credentials for future fixture sync.
# Do not put real keys in git. Copy this to .env.local when you are ready.
API_FOOTBALL_API_KEY=replace-with-your-api-football-key
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=1
API_FOOTBALL_WORLD_CUP_SEASON=2026

# Server-only football-data.org credentials for an alternative fixture provider.
FOOTBALL_DATA_API_TOKEN=replace-with-your-football-data-token
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_WORLD_CUP_COMPETITION_CODE=WC
FOOTBALL_DATA_WORLD_CUP_SEASON=2026

# Server-only Odds-API.io credentials for future odds discovery.
ODDS_API_IO_KEY=replace-with-your-odds-api-io-key
ODDS_API_IO_BASE_URL=https://api.odds-api.io/v3

# Server-only The Odds API credentials for discovery-only outright winner odds.
THE_ODDS_API_KEY=replace-with-your-the-odds-api-key
THE_ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
